import sympy as sp
import numpy as np
from tabulate import tabulate

x = sp.symbols('x')
a=np.linspace(0,10,11)
expression = "x^2+3x-1".replace("^","**").replace("x","*x")




expression = sp.sympify(expression)
f=sp.lambdify(x, expression, "numpy")

print(tabulate(headers=["x","f(x)"],tabular_data=zip(a,f(a))))
print(expression)

